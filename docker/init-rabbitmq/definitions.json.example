{
  "vhosts": [
    { "name": "/" }
  ],
  "users": [
    {
      "name": "actionow",
      "password_hash": "REPLACE_WITH_GENERATED_HASH",
      "hashing_algorithm": "rabbit_password_hashing_sha256",
      "tags": ["administrator"]
    }
  ],
  "permissions": [
    {
      "user": "actionow",
      "vhost": "/",
      "configure": ".*",
      "write": ".*",
      "read": ".*"
    }
  ],
  "policies": [
    {
      "vhost": "/",
      "name": "collab-dlx",
      "pattern": "^(actionow\\.ws\\.notification|actionow\\.collab\\.|actionow\\.agent\\.).*",
      "apply-to": "queues",
      "definition": {
        "dead-letter-exchange": "actionow.dlx",
        "dead-letter-routing-key": "actionow.dlq"
      },
      "priority": 0
    }
  ]
}
